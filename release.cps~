#include <iostream>
#include <cmath>
#include <clocale>
#include <limits>

using namespace std;

const double PI = 3.14159265358979323846;

// ---------- ¿¿¿¿¿¿¿¿¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿ ¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿ ¿¿¿¿¿ ¿¿¿¿¿ ----------
template<typename T>
bool inputNumber(T& value, const string& prompt) {
    cout << prompt;
    if (cin >> value) {
        return true;
    } else {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "¿¿¿¿¿¿: ¿¿¿¿¿¿¿ ¿¿¿¿¿.\n";
        return false;
    }
}

// ---------- ¿¿¿¿¿¿¿¿¿¿¿¿¿ ----------
void rectangle() {
    double a, b;
    if (!inputNumber(a, "¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿¿¿ (a b): ")) return;
    if (!inputNumber(b, "")) return;  // ¿¿¿¿¿¿ ¿¿¿¿¿ ¿¿¿¿¿¿¿¿ ¿ ¿¿¿ ¿¿ ¿¿¿¿¿¿, ¿¿ ¿¿¿ ¿¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿

    if (a <= 0 || b <= 0) {
        cout << "¿¿¿¿¿¿: ¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿¿¿ ¿¿¿¿¿¿ ¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿¿¿!\n";
        return;
    }

    double perimeter = 2 * (a + b);
    double area = a * b;
    double diagonal = sqrt(a * a + b * b);

    cout << "\n¿¿¿¿¿¿¿¿¿¿¿¿¿:\n"
         << "¿¿¿¿¿¿¿¿: " << perimeter << "\n"
         << "¿¿¿¿¿¿¿: " << area << "\n"
         << "¿¿¿¿¿¿¿¿¿: " << diagonal << "\n";
}

// ---------- ¿¿¿¿¿¿¿¿ ----------
void trapezoid() {
    double a, b, c, d;
    cout << "¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿¿ ¿ ¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿ (a b c d): ";
    if (!(cin >> a >> b >> c >> d)) {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "¿¿¿¿¿¿: ¿¿¿¿¿¿¿ ¿¿¿¿¿¿ ¿¿¿¿¿.\n";
        return;
    }

    if (a <= 0 || b <= 0 || c <= 0 || d <= 0) {
        cout << "¿¿¿¿¿¿: ¿¿¿¿¿¿¿ ¿¿¿¿¿¿ ¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿¿¿!\n";
        return;
    }

    double perimeter = a + b + c + d;
    double midLine = (a + b) / 2;

    cout << "\n¿¿¿¿¿¿¿¿:\n"
         << "¿¿¿¿¿¿¿¿: " << perimeter << "\n"
         << "¿¿¿¿¿¿¿ ¿¿¿¿¿: " << midLine << "\n";
}

// ---------- ¿¿¿¿¿¿¿¿¿¿¿ ----------
void triangle() {
    double a, b, c;
    cout << "¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿: ";
    if (!(cin >> a >> b >> c)) {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "¿¿¿¿¿¿: ¿¿¿¿¿¿¿ ¿¿¿ ¿¿¿¿¿.\n";
        return;
    }

    if (a <= 0 || b <= 0 || c <= 0) {
        cout << "¿¿¿¿¿¿: ¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿ ¿¿¿¿¿¿ ¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿¿¿!\n";
        return;
    }

    if (a + b <= c || a + c <= b || b + c <= a) {
        cout << "¿¿¿¿¿¿: ¿¿¿¿¿¿¿¿¿¿¿¿ ¿ ¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿¿ ¿¿ ¿¿¿¿¿¿!\n";
        return;
    }

    double perimeter = a + b + c;
    double semiperimeter = perimeter / 2;
    double area = sqrt(semiperimeter * (semiperimeter - a) *
                      (semiperimeter - b) * (semiperimeter - c));

    bool isIsosceles = (a == b || a == c || b == c);

    cout << "\n¿¿¿¿¿¿¿¿¿¿¿\n"
         << "¿¿¿¿¿¿¿¿: " << perimeter << "\n"
         << "¿¿¿¿¿¿¿ (¿¿ ¿¿¿¿¿¿¿ ¿¿¿¿¿¿): " << area << "\n"
         << (isIsosceles ? "¿¿¿¿¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿¿¿.\n" : "¿¿¿¿¿¿¿¿¿¿¿ ¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿¿¿.\n");
}

// ---------- ¿¿¿¿ ----------
double squareOfSectorOfCircle(double radius, double angleDegrees = 360.0) {
    return radius * radius * angleDegrees * PI / 360.0;
}

double lengthOfCircle(double radius) {
    return 2.0 * PI * radius;
}

void circle() {
    double radius;
    if (!inputNumber(radius, "¿¿¿¿¿¿¿ ¿¿¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿: ")) return;
    if (radius <= 0) {
        cout << "¿¿¿¿¿¿ ¿¿¿¿¿¿ ¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿¿¿¿.\n";
        return;
    }

    double angle;
    if (!inputNumber(angle, "¿¿¿¿¿¿¿ ¿¿¿¿ ¿¿¿¿¿¿¿ ¿ ¿¿¿¿¿¿¿¿ (0 < ¿¿¿¿ < 360): ")) return;
    if (angle <= 0 || angle >= 360) {
        cout << "¿¿¿¿ ¿¿¿¿¿¿ ¿¿¿¿ ¿ ¿¿¿¿¿¿¿¿¿ (0, 360).\n";
        return;
    }

    double fullCircleArea = squareOfSectorOfCircle(radius);
    double sectorArea = squareOfSectorOfCircle(radius, angle);
    double circumference = lengthOfCircle(radius);

    cout << "\n¿¿¿¿¿ ¿¿¿¿¿¿¿¿¿¿ = " << circumference << "\n"
         << "¿¿¿¿¿¿¿ ¿¿¿¿¿ = " << fullCircleArea << "\n"
         << "¿¿¿¿¿¿¿ ¿¿¿¿¿¿¿ (" << angle << "°) = " << sectorArea << "\n";
}

